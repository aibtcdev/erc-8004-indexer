{
  "name": "erc-8004-indexer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "wrangler": "set -a && . ./.env && set +a && npx wrangler",
    "dev": "npm run wrangler -- dev",
    "deploy:dry-run": "npm run wrangler -- deploy --dry-run",
    "deploy:staging": "npm run wrangler -- deploy --env staging",
    "deploy:production": "npm run wrangler -- deploy --env production",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "npm run wrangler -- types"
  },
  "dependencies": {
    "@hirosystems/chainhooks-client": "^2.1.1",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.2",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/node": "^25.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.77.0"
  }
}
