# ERC-8004 Indexer — Environment Variables
#
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by `npm run wrangler` (via set -a && . ./.env).
# Scripts in scripts/ read these vars directly via process.env.

# ── Hiro API ─────────────────────────────────────────────────────────────────

# Hiro API key for authenticating with api.mainnet.hiro.so / api.testnet.hiro.so
# Get one at: https://platform.hiro.so
# Used by: npm run register, npm run check-chainhook, npm run backfill,
#          and the cron-based scheduled health check (src/scheduled.ts)
HIRO_API_KEY=your-hiro-api-key-here

# ── Chainhooks Registration ───────────────────────────────────────────────────

# Network to target: "mainnet" or "testnet" (default: testnet)
CHAINHOOK_NETWORK=testnet

# Public URL of the deployed worker (used as the webhook action URL)
# The /webhook path is appended automatically by the register script.
# Example: https://erc8004.aibtc.dev
WEBHOOK_URL=https://your-worker.workers.dev

# Optional: Stacks block height to start indexing from (default: 0 = full history)
# Set to a recent block to avoid replaying the entire chain on first registration.
# Testnet safe start: ~170000, Mainnet safe start: ~175000
START_BLOCK_HEIGHT=0

# ── Cloudflare KV (for storing chainhook UUID after registration) ─────────────

# Cloudflare account ID (found in the Cloudflare dashboard URL)
CF_ACCOUNT_ID=your-cloudflare-account-id

# KV namespace ID for INDEXER_KV (staging or production namespace)
# Run: npx wrangler kv:namespace list  to find the correct ID
CF_KV_NAMESPACE_ID=your-kv-namespace-id

# ── Worker Secrets (set via `wrangler secret put`, not in .env) ───────────────

# Consumer secret for webhook authentication (Bearer token validation in the worker)
# Generated by: npm run rotate-secret
# Set in worker via: npx wrangler secret put CHAINHOOK_SECRET
CHAINHOOK_SECRET=your-consumer-secret-hex

# ── Chainhook Health Check / Backfill ────────────────────────────────────────

# UUID of the registered chainhook (stored in KV after npm run register)
# Used by: npm run check-chainhook, npm run backfill
CHAINHOOK_UUID=your-chainhook-uuid-here

# ── Backfill Script ───────────────────────────────────────────────────────────

# Block height to end the backfill at (optional).
# If not set, npm run backfill fetches the current tip height automatically.
# END_BLOCK_HEIGHT=

# ── Admin API ─────────────────────────────────────────────────────────────────

# Bearer token for lens management endpoints (POST /api/v1/lenses, PUT /api/v1/lenses/:lens).
# If not set, admin endpoints return 403 Forbidden.
# Set in worker via: npx wrangler secret put ADMIN_TOKEN
ADMIN_TOKEN=your-admin-token-here
